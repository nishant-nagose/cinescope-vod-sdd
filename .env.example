# CineScope Application - Environment Configuration
# Get your free TMDB API key from: https://www.themoviedb.org/settings/api

# ============================================
# TMDB API Configuration
# ============================================
VITE_TMDB_API_KEY=2e1025cc7e5b7674b5c36f2205cc0e15

# API Base URL (TMDB)
VITE_API_BASE_URL=https://api.themoviedb.org/3

# Image CDN Base URL (TMDB)
VITE_IMAGE_BASE_URL=https://image.tmdb.org/t/p

# ============================================
# Caching Configuration
# ============================================
# Cache duration in milliseconds (default: 5 minutes)
VITE_CACHE_TTL=300000

# ============================================
# Environment Settings
# ============================================
# Environment: development or production
VITE_ENV=development

# Development server port
VITE_PORT=5173

# Enable debug logging
VITE_DEBUG=false